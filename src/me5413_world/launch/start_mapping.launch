<launch>
  <param name="/use_sim_time" value="true" />

  <node pkg="slam_toolbox" type="async_slam_toolbox_node" name="slam_toolbox" output="screen">
    <rosparam command="load" file="$(find me5413_world)/config/my_mapper_params.yaml" />
    
    <param name="scan_topic" value="/front/scan" />
    <param name="odom_frame" value="odom" />
    <param name="base_frame" value="base_link" />
    <param name="map_frame" value="map" />
    
    <param name="transform_publish_period" value="0.05" />
    <param name="map_update_interval" value="2.0" />
  </node>

  <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" name="teleop" output="screen" launch-prefix="xterm -e" />

  <arg name="rviz_config" default="$(find me5413_world)/rviz/gmapping.rviz" />
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(arg rviz_config)" respawn="true" />
</launch>
